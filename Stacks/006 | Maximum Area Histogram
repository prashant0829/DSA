// Online C++ compiler to run C++ program online
// Sample Array
// 6 2 5 4 5 1 6
#include <iostream>
#include <vector>
#include <stack>

using namespace std;

int main()
{

    int n;

    cout << "Enter the size of the array\n";
    cin >> n;
    vector<int> v(n);
    cout << "Your array size is " << n << "\n";
    cout << "Enter the array\n";

    for (int i = 0; i < n; i++)
    {
        cin >> v[i];
    }

    stack<pair<int, int>> s1;
    stack<pair<int, int>> s2;

    vector<int> r1(n);
    vector<int> r2(n);

    // NSR
    for (int i = 0; i < n; i++)
    {
        while (!s1.empty() && s1.top().second >= v[i])
        {
            s1.pop();
        }

        r1[i] = s1.empty() ? -1 : s1.top().first;

        s1.push({i, v[i]});
    }

    // NSL
    for (int i = n - 1; i >= 0; i--)
    {
        while (!s2.empty() && s2.top().second >= v[i])
        {
            s2.pop();
        }

        r2[i] = s2.empty() ? n : s2.top().first;

        s2.push({i, v[i]});
    }

    for (int i = 0; i < n; i++)
    {
        cout << r1[i] << " ";
    }
    cout << "\n";
    for (int i = 0; i < n; i++)
    {
        cout << r2[i] << " ";
    }
    cout << "\n";
    int maxArea = 0;

    for (int i = 0; i < n; i++)
    {
        int area = (r2[i] - r1[i] - 1) * v[i];
        cout << area << " ";
        maxArea = max(maxArea, area);
    }

    cout << "\nMax Area: " << maxArea << endl;

    return 0;
}